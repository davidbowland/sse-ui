{
  "name": "sse-ui",
  "version": "1.23.0",
  "description": "UI for Spectrum Street Epistemology",
  "author": "David Bowland",
  "engines": {
    "node": "^24.0.0"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidbowland/sse-ui.git"
  },
  "bugs": {
    "url": "https://github.com/davidbowland/sse-ui/issues"
  },
  "homepage": "https://github.com/davidbowland/sse-ui#readme",
  "scripts": {
    "build": "npm run clean && next build",
    "postbuild": "node scripts/generate-dynamic-pages.js && next-sitemap",
    "clean": "rm -rf .next coverage out && npm ci --legacy-peer-deps",
    "start": "next dev",
    "serve": "next build && npx serve out",
    "test": "jest --colors",
    "lint": "prettier --write . && eslint --fix .",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "update": "npx update-browserslist-db@latest && ncu --doctor --target minor --upgrade && npm audit fix --audit-level=none && npm run test && npm dedupe"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^5.3.3",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.6",
    "@mui/icons-material": "^5.18.0",
    "@mui/lab": "^5.0.0-alpha.177",
    "@mui/material": "^5.18.0",
    "@mui/x-data-grid": "^6.20.4",
    "aws-amplify": "^5.3.27",
    "axios": "^1.11.0",
    "axios-retry": "^4.5.0",
    "babel-plugin-styled-components": "^2.1.4",
    "husky": "^9.1.7",
    "next": "^15.0.0",
    "next-sitemap": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-material-ui-carousel": "^3.4.2",
    "styled-components": "^5.3.11",
    "typescript": "^5.9.2",
    "universal-cookie": "^4.0.4"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/styled-components": "^5.1.34",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-react": "^7.37.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.6.2",
    "react-test-renderer": "^19.0.0",
    "undici": "^6.21.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write --ignore-unknown",
      "eslint --fix",
      "jest --colors --findRelatedTests --coverageThreshold '{}' --passWithNoTests"
    ],
    "**/*": [
      "prettier --write --ignore-unknown"
    ]
  }
}
