{
  "name": "sse-ui",
  "version": "1.26.0",
  "description": "UI for Spectrum Street Epistemology",
  "author": "David Bowland",
  "engines": {
    "node": "^24.0.0"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/davidbowland/sse-ui.git"
  },
  "bugs": {
    "url": "https://github.com/davidbowland/sse-ui/issues"
  },
  "homepage": "https://github.com/davidbowland/sse-ui#readme",
  "scripts": {
    "build": "npm run clean && next build",
    "postbuild": "node scripts/generate-dynamic-pages.js && next-sitemap",
    "clean": "rm -rf .next coverage out && npm ci",
    "start": "next dev",
    "serve": "next build && npx serve out",
    "test": "jest --colors",
    "lint": "prettier --write . && eslint --fix .",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "update": "npx update-browserslist-db@latest && ncu --doctor --target minor --upgrade && npm audit fix --audit-level=none && npm run test && npm dedupe"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^5.3.3",
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/roboto": "^5.2.10",
    "@heroui/react": "^3.2.1",
    "@tanstack/react-query": "^5.101.2",
    "aws-amplify": "^5.3.35",
    "axios": "^1.18.1",
    "axios-retry": "^4.5.0",
    "framer-motion": "^12.42.0",
    "husky": "^9.1.7",
    "lucide-react": "^1.22.0",
    "next": "^15.5.19",
    "next-sitemap": "^4.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.10.2",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-react": "^7.37.5",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.4",
    "react-test-renderer": "^19.2.7",
    "undici": "^6.27.0"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write --ignore-unknown",
      "eslint --fix",
      "jest --colors --findRelatedTests --coverageThreshold '{}' --passWithNoTests"
    ],
    "**/*": [
      "prettier --write --ignore-unknown"
    ]
  }
}
