{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "jsx": "preserve",
    "strict": true,
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/components/*"],
      "@config/*": ["src/config/*"],
      "@hooks/*": ["src/hooks/*"],
      "@pages/*": ["src/pages/*"],
      "@services/*": ["src/services/*"],
      "@test/*": ["test/*"],
      "@types": ["src/types"]
    },
    "plugins": [{ "name": "next" }],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  }
}
